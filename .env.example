# UIBenchKit API Server - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# UIBenchKit API Server Configuration
# =============================================================================
# API key for authenticating with the UIBenchKit server
UIBENCHKIT_API_KEY=your-secure-api-key-here

# =============================================================================
# Model API Keys
# =============================================================================
# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Key (for GPT-4 models)
OPENAI_API_KEY=your-openai-api-key
# Alternative aliases accepted by the API/CLI:
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENAI_COMPAT_API_KEY=your-openai-compatible-key

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your-anthropic-api-key
# Alternative alias:
# CLAUDE_API_KEY=your-anthropic-api-key

# Alibaba Qwen API Key
QWEN_API_KEY=your-qwen-api-key
# Alternative alias:
# DASHSCOPE_API_KEY=your-dashscope-key

# =============================================================================
# Optional Configuration
# =============================================================================
# Custom OpenAI-compatible API base URL (e.g., for proxies)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Additional base-url aliases (also supported):
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# HuggingFace token for downloading datasets
# HF_TOKEN=your-huggingface-token

# =============================================================================
# Method-specific optional env vars
# =============================================================================
# LayoutCoder project path override (if using external LayoutCoder repo)
# LAYOUTCODER_PROJECT_PATH=/absolute/path/to/LayoutCoder

# AWS Bedrock credentials (for mistral/llama families)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

