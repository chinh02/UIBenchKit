# DCGen API Server - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# DCGen API Server Configuration
# =============================================================================
# API key for authenticating with the DCGen server
DCGEN_API_KEY=your-secure-api-key-here

# =============================================================================
# Model API Keys
# =============================================================================
# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Key (for GPT-4 models)
OPENAI_API_KEY=your-openai-api-key

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Alibaba Qwen API Key
QWEN_API_KEY=your-qwen-api-key

# =============================================================================
# Optional Configuration
# =============================================================================
# Custom OpenAI-compatible API base URL (e.g., for proxies)
# OPENAI_BASE_URL=https://api.openai.com/v1

# HuggingFace token for downloading datasets
# HF_TOKEN=your-huggingface-token
